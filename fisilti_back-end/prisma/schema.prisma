generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)   // false = banlı
  role          Role      @default(USER)
  country       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // İlişkiler
  emailVerifications EmailVerification[]
  posts              Post[]
  following          Follow[]  @relation("Follower")
  followers          Follow[]  @relation("Following")
  reports            Report[]
  savedPosts         SavedPost[]
  adminLogs          AdminLog[]
}

model EmailVerification {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Post {
  id        Int      @id @default(autoincrement())
  userId    Int
  content   String   @db.Text
  isActive  Boolean  @default(true)   // false = gizlenmiş (soft delete)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  reports    Report[]
  savedPosts SavedPost[]
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  follower    User     @relation("Follower",  fields: [followerId],  references: [id])
  following   User     @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Report {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  reason    String?
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model SavedPost {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

enum Role {
  USER
  ADMIN
}

model AdminLog {
  id         Int      @id @default(autoincrement())
  adminId    Int
  action     String   // "BAN_USER", "UNBAN_USER", "HIDE_POST"
  targetId   Int      // userId veya postId
  targetType String   // "USER" veya "POST"
  note       String?
  createdAt  DateTime @default(now())

  admin      User     @relation(fields: [adminId], references: [id])
}
